{
  "name": "bu-wp-docker",
  "version": "0.0.1",
  "description": "Container definition for BU WordPress",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "export CACHEBUST=$(date +%s) && docker compose -f docker-compose.build.yml build",
    "build:nocache": "export CACHEBUST=$(date +%s) && docker compose -f docker-compose.build.yml build --no-cache",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "shell": "docker compose exec wordpress bash",
    "logs": "docker compose logs -f",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whennemuth/bu-wp-docker.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/whennemuth/bu-wp-docker/issues"
  },
  "homepage": "https://github.com/whennemuth/bu-wp-docker#readme"
}
